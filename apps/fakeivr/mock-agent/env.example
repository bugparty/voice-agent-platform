# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Or use Azure OpenAI
# AZURE_OPENAI_API_KEY=your_azure_key
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT=your-deployment-name

# Or use Anthropic Claude
# ANTHROPIC_API_KEY=your_anthropic_key

# Agent Configuration
LLM_PROVIDER=openai
# Options: openai, azure, anthropic
MODEL_NAME=gpt-4o-mini
# For OpenAI: gpt-4, gpt-4-turbo, gpt-3.5-turbo
# For Anthropic: claude-3-opus-20240229, claude-3-sonnet-20240229

# IVR Scenario Selection
IVR_TREE_PATH=data/ivr-simple.json
# Options:
#   data/ivr-simple.json   - Easy 6-menu demo (default)
#   data/ivr-complex.json  - Realistic 87-menu pharmacy system
#   data/ivr-fault.json    - Impossible scenario (no human available)
#   data/ivr-hide.json     - Hidden option scenario (press 0 for human)

# Simulation Settings
MAX_ATTEMPTS=20
# Maximum number of menu selections before giving up
ALLOW_MISTAKES=true
# Whether agent can make wrong choices (for learning simulation)
MISTAKE_PROBABILITY=0.15
# Probability of making a mistake (0.0 to 1.0)
