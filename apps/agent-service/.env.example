# Agent Service Configuration

# Media service gRPC server address
MEDIA_SERVICE_GRPC_URL=localhost:50052

# Session ID to subscribe to (for testing)
SESSION_ID=test-session

# Event filters (comma-separated)
EVENT_FILTERS=vad.*,asr.*,call.*

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Directory for replayable event logs
EVENT_LOG_DIR=logs/agent-events

# Future: OpenAI API key for LLM integration
# OPENAI_API_KEY=sk-xxx
