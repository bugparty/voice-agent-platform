# Agent Service Configuration

# Media service gRPC server address
MEDIA_SERVICE_GRPC_URL=localhost:50052

# Session ID to subscribe to (for testing)
SESSION_ID=test-session

# Event filters (comma-separated)
EVENT_FILTERS=vad.*,asr.*,call.*

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Directory for replayable event logs
EVENT_LOG_DIR=logs/agent-events

# OpenAI Configuration
# API key (required for LLM integration)
OPENAI_API_KEY=sk-xxx

# Custom API base URL (optional, for OpenAI-compatible services like Azure, local LLMs)
# OPENAI_API_URL=https://api.openai.com/v1

# Model to use (optional, default: gpt-4.1-mini)
OPENAI_MODEL=gpt-4.1-mini
